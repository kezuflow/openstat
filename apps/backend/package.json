{
  "name": "backend",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx src/worker.ts",
    "seed:dev": "tsx src/scripts/seed-dev.ts",
    "retention:sweep": "node dist/scripts/sweep-retention.js",
    "retention:sweep:dev": "tsx src/scripts/sweep-retention.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm --filter @openstat/db --filter @openstat/schemas --filter @openstat/auth --filter @openstat/ingestion build",
    "test": "vitest run",
    "pretest:integration": "pnpm --filter @openstat/db --filter @openstat/schemas --filter @openstat/auth --filter @openstat/ingestion build",
    "test:integration": "vitest run src/ingestion.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@openstat/auth": "workspace:*",
    "@openstat/db": "workspace:*",
    "@openstat/ingestion": "workspace:*",
    "@openstat/schemas": "workspace:*",
    "@sentry/node": "^10.61.0",
    "better-auth": "^1.6.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
