{
  "name": "deepbook-agent",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build:sdk": "pnpm --filter openstat build",
    "build": "pnpm run build:sdk && tsc -p tsconfig.json",
    "check-types": "pnpm run build:sdk && tsc --noEmit",
    "claim-loop": "pnpm run build:sdk && tsx src/index.ts --claim-loop",
    "dry-run": "pnpm run build:sdk && tsx src/index.ts --dry-run",
    "replay": "pnpm run build:sdk && tsx src/index.ts",
    "test": "pnpm run build:sdk && vitest run src"
  },
  "dependencies": {
    "openstat": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsx": "^4.20.6",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  }
}
