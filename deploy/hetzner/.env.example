NODE_ENV=production
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

API_DOMAIN=api.openstat.example.com
ACME_EMAIL=admin@example.com
API_PUBLIC_URL=https://api.openstat.example.com
APP_WEB_URL=https://openstat-web.vercel.app
BETTER_AUTH_URL=https://api.openstat.example.com
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_COOKIE_DOMAIN=.openstat.example.com
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_EMAIL_PROVIDER=resend
AUTH_EMAIL_FROM="OpenStat <noreply@openstat.online>"
RESEND_API_KEY=replace-with-resend-api-key

POSTGRES_DB=openstat
POSTGRES_USER=openstat
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://openstat:replace-with-a-long-random-password@postgres:5432/openstat
REDIS_URL=redis://redis:6379

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

OPENSTAT_DEMO_EMAIL=demo@openstat.local
OPENSTAT_DEMO_PASSWORD=openstat-local-demo-password

INGESTION_MAX_BODY_BYTES=1000000
INGESTION_RATE_LIMIT_MAX=600
INGESTION_RATE_LIMIT_WINDOW=1 minute
DEFAULT_AGENT_STALE_SECONDS=180
DEFAULT_AGENT_OFFLINE_SECONDS=600
INGESTION_WORKER_BATCH_SIZE=100
INGESTION_WORKER_POLL_MS=1000
INGESTION_LOCK_TTL_SECONDS=60
INGESTION_WORKER_MAX_ATTEMPTS=5
MANTLE_RECONCILIATION_ENABLED=true
MANTLE_ANCHOR_INDEXING_ENABLED=false
CHAIN_RECONCILIATION_INTERVAL_MS=15000
CHAIN_RPC_TIMEOUT_MS=10000
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA_ANCHOR_CONTRACT_ADDRESS=
MANTLE_ANCHOR_INDEX_START_BLOCK=
BASE_RECONCILIATION_ENABLED=false
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BNB_RECONCILIATION_ENABLED=false
BNB_MAINNET_RPC_URL=https://bsc-dataseed.bnbchain.org
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
RETENTION_SWEEP_ENABLED=true
RETENTION_SWEEP_INTERVAL_MS=3600000
RAW_RETENTION_DAYS=30
DERIVED_RETENTION_DAYS=365
