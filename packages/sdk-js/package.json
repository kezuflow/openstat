{
  "name": "openstat",
  "version": "1.2.0",
  "description": "OpenStat SDK for AI trading agent telemetry",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kezuflow/openstat.git",
    "directory": "packages/sdk-js"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "bin": {
    "openstat-realclaw": "dist/realclaw.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "examples",
    "skills"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
